# Anthropic API key for the Claude Agent SDK
ANTHROPIC_API_KEY=

# Google OAuth client (Calendar + Tasks APIs enabled).
# Authorized redirect URI must include: http://localhost:8788/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 64-character hex string used to encrypt the local token store (~/.concierge/store.json).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONCIERGE_ENCRYPTION_KEY=

# Hevy API key (https://hevy.com/settings?developer) — used by the Hevy stdio MCP server.
HEVY_API_KEY=

# Optional overrides
# CONCIERGE_MODEL=claude-sonnet-4-6
# HEVY_MCP_ENTRY=/Users/jakob/dev/projects/hevy/src/local.ts
# GOOGLE_OAUTH_PORT=8788
